.env
package-lock.json
launch.json
.eslintrc.json
.vscode
.prettierrc

# Data directory (contains sensitive trading data)
data/

# User's personal strategy (override)
# Note: strategy.example.json is tracked in git as default
# strategy.json is user-specific and gitignored via data/ above

# default Node gitignore follows

# Logs
logs
*.log
npm-debug.log*

# Runtime data
pids
*.pid
*.seed

# Directory for instrumented libs generated by jscoverage/JSCover
lib-cov

# Coverage directory used by tools like istanbul
coverage

# nyc test coverage
.nyc_output

# Grunt intermediate storage (http://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# node-waf configuration
.lock-wscript

# Compiled binary addons (http://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules
jspm_packages

# Optional npm cache directory
.npm

# Optional REPL history
.node_repl_history
